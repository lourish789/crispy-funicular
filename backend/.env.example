# ===== AgriTech Suite Backend Configuration =====

# Security
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=sqlite:///./agritech.db

# LLM (Groq) — text generation & vision
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
# Multimodal model for image/video diagnosis (alt: qwen/qwen3.6-27b)
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Embeddings (Google Gemini) — used EXCLUSIVELY for vectorization / RAG
GEMINI_API_KEY=your-gemini-api-key
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# News aggregator (NewsAPI.org or GNews — optional; graceful fallback if unset)
NEWS_API_KEY=your-news-api-key
NEWS_CACHE_TTL_SECONDS=1800

# Firebase Authentication (optional — enables /api/auth/firebase sign-in)
# Provide EITHER a path to a service-account JSON, OR the raw JSON inline,
# OR just the project id (to use Application Default Credentials / emulator).
FIREBASE_CREDENTIALS_FILE=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_PROJECT_ID=

# CORS
FRONTEND_ORIGIN=http://localhost:5173

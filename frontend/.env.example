# Base URL of the AgriTech backend API. Leave blank to use the Vite dev proxy.
VITE_API_BASE=
# Target the dev proxy forwards /api to (used only in development)
VITE_API_TARGET=http://localhost:8000

# Firebase web app config (optional — enables "Continue with Google").
# Get these from Firebase console > Project settings > Your apps > SDK setup.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
